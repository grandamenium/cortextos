# AscendOps Property Management Agent — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Telegram Bot (required)
BOT_TOKEN=
CHAT_ID=
ALLOWED_USER=

# Property Meld API (optional — set during onboarding)
MELD_API_KEY=

# Twilio SMS (optional — set during onboarding)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# AscendOps branding (set to 1 for branded CLI/dashboard)
ASCENDOPS_BRAND=1
