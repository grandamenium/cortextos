# Standard agent environment variables
# Copy this file to .env and fill in your values.
# NEVER commit a populated .env file.

# Telegram bot for this specific agent (required)
BOT_TOKEN=
CHAT_ID=

# Required if BOT_TOKEN is set. Comma-separated list of Telegram user IDs
# allowed to message this agent. Use numeric IDs, not usernames.
ALLOWED_USER=

# Optional: Google Workspace account for gws-connected workflows
# GWS_ACCOUNT=you@example.com

# Optional: shared provider override for this agent only
# OPENAI_API_KEY=

# Optional: revert Sonnet/Haiku to 200K context if your plan does not support 1M
# CLAUDE_CODE_DISABLE_1M_CONTEXT=true
