{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "kb-gap.schema.json",
  "title": "Support KB Gap",
  "type": "object",
  "required": [
    "id",
    "created_at",
    "ticket_ids",
    "question",
    "gap_type",
    "impact",
    "suggested_fix"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "ticket_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "question": {
      "type": "string"
    },
    "gap_type": {
      "type": "string",
      "enum": [
        "missing-doc",
        "unclear-doc",
        "missing-macro",
        "stale-policy",
        "bug",
        "product-feedback"
      ]
    },
    "impact": {
      "type": "string"
    },
    "attempted_sources": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "suggested_fix": {
      "type": "string"
    },
    "owner": {
      "type": "string"
    }
  }
}
