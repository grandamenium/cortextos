{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cortextos.local/schemas/concierge/starter-team.schema.json",
  "title": "Concierge Starter Team Recommendation",
  "type": "object",
  "required": ["version", "created_at", "recommended_agents", "approval_required", "deferred_agents"],
  "properties": {
    "version": { "type": "string" },
    "created_at": { "type": "string" },
    "basis": { "type": "string" },
    "recommended_agents": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["template", "role", "why", "first_task"],
        "properties": {
          "template": { "type": "string" },
          "agent_name": { "type": "string" },
          "role": { "type": "string" },
          "why": { "type": "string" },
          "first_task": { "type": "string" },
          "dependencies": { "type": "array", "items": { "type": "string" } },
          "approval_status": { "enum": ["not_requested", "requested", "approved", "rejected"] }
        },
        "additionalProperties": false
      }
    },
    "approval_required": { "type": "boolean" },
    "alternatives_considered": { "type": "array", "items": { "type": "string" } },
    "deferred_agents": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false
}
