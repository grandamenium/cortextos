{
  "platforms": [
    {
      "name": "LinkedIn",
      "handle": "@example-studio",
      "mode": "draft_only",
      "formats": ["text_post", "document_carousel"],
      "cadence": "3 drafts per week",
      "tooling": {
        "research": ["manual exports", "browser"],
        "draft_storage": "content/drafts",
        "scheduling": "manual after approval",
        "analytics": "manual CSV export"
      },
      "constraints": ["No external post or comment without approval."]
    },
    {
      "name": "YouTube",
      "handle": "@example",
      "mode": "research_only",
      "formats": ["short_video", "long_video"],
      "cadence": "ideas only until setup is complete",
      "tooling": {
        "research": ["platform dashboard"],
        "draft_storage": "content/drafts",
        "scheduling": "disabled",
        "analytics": "manual export"
      },
      "constraints": ["Do not upload or edit videos from this agent."]
    }
  ],
  "default_approval_policy": {
    "external_actions_require_approval": true,
    "allowed_without_approval": ["local research", "local drafts", "local analytics summaries"],
    "always_requires_approval": ["publish", "schedule", "comment", "reply", "dm", "edit", "delete", "profile_change"]
  }
}
