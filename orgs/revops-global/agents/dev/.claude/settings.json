{
  "statusLine": {
    "type": "command",
    "command": "cortextos bus hook-context-status",
    "refreshInterval": 5,
    "timeout": 2
  },
  "permissions": {
    "allow": [
      "Bash",
      "Read",
      "Edit",
      "Write",
      "WebFetch",
      "WebSearch",
      "mcp__qmd__*"
    ]
  },
  "hooks": {
    "PermissionRequest": [
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "cortextos bus hook-planmode-telegram",
            "timeout": 1860
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "cortextos bus hook-permission-telegram",
            "timeout": 1860
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cortextos bus hook-loop-detector",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "cortextos bus hook-policy-check",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "(Write|Edit)",
        "hooks": [
          {
            "type": "command",
            "command": "cortextos bus hook-env-write-guard",
            "timeout": 3
          }
        ]
      },
      {
        "matcher": "mcp__rgos__instantly_*",
        "hooks": [
          {
            "type": "command",
            "command": "cortextos bus hook-policy-check-mcp",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "AskUserQuestion",
        "hooks": [
          {
            "type": "command",
            "command": "cortextos bus hook-ask-telegram",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cortextos bus hook-session-restore",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cortextos bus hook-idle-flag",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cortextos crash-alert",
            "timeout": 10
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node /home/cortextos/cortextos/scripts/sync-agent-memories.js",
            "timeout": 30
          }
        ]
      }
    ],
    "PreCompact": [],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cortextos bus hook-agent-task-event",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "(Skill|Read)",
        "hooks": [
          {
            "type": "command",
            "command": "cortextos bus hook-skill-telemetry",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "cortextos bus hook-blocked-auto-rotate",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "enabledMcpjsonServers": [
    "qmd"
  ]
}
