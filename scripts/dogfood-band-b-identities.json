        "request with photo lands in admin panel",
        "tuner reference pitch is visible and stable"
      ],
      "selectors": {
        "login_email": "input[type=\"email\"]",
        "login_password": "input[type=\"password\"]",
        "login_submit": "button[type=\"submit\"]",
        "success_text": "text=/request|chord|library/i"
