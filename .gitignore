node_modules/
.claude/
!.claude/commands/
!.claude/commands/**
!.claude/orchestration-cortextos-node/
# Include template .claude dirs (needed for agent settings.json)
!templates/**/.claude/
!templates/**/.claude/**
dist/
ecosystem.config.js

# Build / tooling scratch artifacts (never commit)
.next/
.obsidian/
.playwright-mcp/

# User-created org data (not part of the framework)
orgs/
# But community subdirectories ARE part of the framework
!community/
!community/**
# Agent config.json holds cron schedules — persist across daemon reinstalls.
# Must un-ignore each directory level so git can traverse to the file.
!orgs/
!orgs/phytomedic/
# Re-ignore org-level dirs that aren't agents (agent-shared, vault, etc.)
orgs/phytomedic/agent-shared/
orgs/phytomedic/vault/
!orgs/phytomedic/agents/
!orgs/phytomedic/agents/*/
# Re-ignore everything inside agent dirs (runtime data, memory, goals, etc.)
orgs/phytomedic/agents/*/**
orgs/phytomedic/agents/*/*
# Except the cron bootstrap config
!orgs/phytomedic/agents/*/config.json

# Secrets
.env
!.env.example
templates/*/.env
.cortextos-env

# Agent runtime data
orgs/*/agents/*/memory/
agents/*/local/
agents/*/telegram-images/
agents/*/memory/

# macOS metadata
.DS_Store

# Test artifacts
test-results/
*.log
# Spurious directory created when ${APPDATA} env var unexpanded during npm link on Windows
${APPDATA}/

# Knowledge base
knowledge-base/venv/
knowledge-base/__pycache__/
knowledge-base/scripts/__pycache__/
knowledge-base/scripts/_test_clients/__pycache__/
tests/playwright/dashboard-ui.spec.ts

# Local ops docs (personal, not for public repo)
docs/

# Internal developer/planning notes (not for public repo)
KNOWN-ISSUES.md
WINDOWS-IMPLEMENTATION-PLAN.md
WINDOWS-SUPPORT-INVESTIGATION.md
BRAINDUMP*.md
AGENTS.md
dashboard/screenshots/
dashboard/test-*.py
# Added by code-review-graph
.code-review-graph/

# Public community agent templates may intentionally include their own docs,
# AGENTS.md, memory skill, and scaffold files.
!community/agents/research-agent/
!community/agents/research-agent/**
