# cortextOS Dashboard Configuration
# Copy to .env and fill in your values

# Required: Path to cortextOS state directory
# Created by `cortextos init` (default: <your-home>/.cortextos/default)
# IMPORTANT: use an ABSOLUTE path. A leading "~" is NOT expanded — the daemon
# (src/utils/paths.ts) and the dashboard read CTX_ROOT verbatim, so both MUST
# see the same absolute path or they resolve different data/KB/socket trees.
CTX_ROOT=/absolute/path/to/.cortextos/default

# Required: Path to the cortextOS repo root
CTX_FRAMEWORK_ROOT=/path/to/cortextos

# Required: Dashboard auth secret — generate with: openssl rand -base64 32
# If unset, the dashboard will refuse to start (no insecure fallback)
AUTH_SECRET=your-secret-here

# Required for reverse-proxy or tunnel setups
AUTH_TRUST_HOST=true

# Dashboard admin credentials (created on first login)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# Dashboard public URL — used for CORS and NextAuth redirects
# Set this to your Cloudflare Tunnel URL or public IP (e.g. https://xyz.trycloudflare.com)
# If unset, only localhost origins are allowed — cross-origin API calls will be blocked
NEXTAUTH_URL=https://your-tunnel.trycloudflare.com

# CORS: Additional allowed origin for the dashboard web UI
# Use if your dashboard runs at a different URL than NEXTAUTH_URL
# DASHBOARD_URL=https://your-dashboard-url.example.com

# CORS: Origin for the cortextOS mobile app (required if using the iOS/Android app)
# Without this, all mobile API calls will be rejected with Access-Control-Allow-Origin: null
# In development, Expo Go typically uses exp://localhost:8083 or the Metro dev server URL
MOBILE_APP_ORIGIN=https://your-tunnel.trycloudflare.com

# Optional: Instance ID (default: "default")
# CTX_INSTANCE_ID=default
